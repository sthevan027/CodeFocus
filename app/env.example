# ============================================
# SUPABASE (Auth + Database com RLS)
# ============================================
# OAuth: habilite GitHub e Google no Supabase Dashboard > Authentication > Providers
# e adicione a URL de callback nas Redirect URLs: https://seu-dominio/api/auth/oauth-callback
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica

# Service role (BYPASSA RLS) — use apenas para admin/health/status (servidor)
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role-secreta

# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Opcional: modo offline (permite fallback localStorage)
NEXT_PUBLIC_OFFLINE_MODE=false

# ============================================
# GITHUB (Integração - repositórios e issues)
# ============================================
# Crie um OAuth App em https://github.com/settings/developers
# IMPORTANTE: Authorization callback URL deve ser EXATAMENTE:
#   - Dev:  http://localhost:3000/api/github/callback
#   - Prod: https://seu-dominio.com/api/github/callback
# O GitHub rejeita se a URL não coincidir. Scope: repo, read:user
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================
# NODE
# ============================================
NODE_ENV=development

