# ========================================
# CodeFocus Backend - Variáveis de Ambiente
# ========================================

# Configurações do Banco de Dados
DATABASE_URL=sqlite:///./codefocus.db

# Configurações de Segurança
SECRET_KEY=your-secret-key-here-change-in-production-use-a-strong-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# URLs da Aplicação
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ========================================
# Configurações do Resend (Email)
# ========================================
# 1. Acesse https://resend.com e crie uma conta
# 2. Obtenha sua API Key no dashboard
# 3. Para desenvolvimento, você pode usar o domínio de teste do Resend
# 4. Para produção, configure seu próprio domínio verificado

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM=noreply@yourdomain.com

# Exemplos de MAIL_FROM:
# Para desenvolvimento: onboarding@resend.dev (domínio de teste)
# Para produção: noreply@seudominio.com (seu domínio verificado)

# ========================================
# Instruções de Configuração
# ========================================
# 1. Copie este arquivo para .env
# 2. Configure sua API Key do Resend
# 3. Ajuste o MAIL_FROM conforme seu domínio
# 4. Para produção, mude o SECRET_KEY
