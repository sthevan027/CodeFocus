
# ========================================
# CodeFocus - Variáveis de Ambiente
# ========================================

# Configurações da API
REACT_APP_API_URL=http://localhost:8000

# Configurações do Backend (se usado)
DATABASE_URL=sqlite:///./codefocus.db
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# URLs da Aplicação
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ========================================
# Configurações de Email (Gmail)
# ========================================

# IMPORTANTE: Use uma "Senha de App" do Gmail, não sua senha normal
# Como criar: https://support.google.com/accounts/answer/185833

MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-de-app
MAIL_FROM=seu-email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_TLS=true
MAIL_SSL=false 