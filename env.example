
# ========================================
# CodeFocus - Variáveis de Ambiente
# ========================================

# Configurações da API
REACT_APP_API_URL=http://localhost:8000

# Configurações do Backend (se usado)
DATABASE_URL=sqlite:///./codefocus.db
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# URLs da Aplicação
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ========================================
# Configurações de Email (Resend)
# ========================================

# 1. Acesse https://resend.com e crie uma conta
# 2. Obtenha sua API Key no dashboard
# 3. Para desenvolvimento: onboarding@resend.dev
# 4. Para produção: configure seu domínio

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM=noreply@yourdomain.com

# Exemplos de MAIL_FROM:
# Desenvolvimento: onboarding@resend.dev
# Produção: noreply@seudominio.com 