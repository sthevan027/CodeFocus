# Configurações OAuth para CodeFocus
# Copie este arquivo para .env e preencha com suas credenciais

# Google OAuth
REACT_APP_GOOGLE_CLIENT_ID=seu_google_client_id_aqui
REACT_APP_GOOGLE_CLIENT_SECRET=seu_google_client_secret_aqui
REACT_APP_GOOGLE_REDIRECT_URI=http://localhost:3000

# GitHub OAuth
REACT_APP_GITHUB_CLIENT_ID=seu_github_client_id_aqui
REACT_APP_GITHUB_CLIENT_SECRET=seu_github_client_secret_aqui
REACT_APP_GITHUB_REDIRECT_URI=http://localhost:3000

# Exemplo de como obter as credenciais:
# 
# GOOGLE:
# 1. Acesse https://console.cloud.google.com
# 2. Crie um projeto ou selecione um existente
# 3. Vá para "APIs & Services" > "Credentials"
# 4. Clique em "Create Credentials" > "OAuth 2.0 Client IDs"
# 5. Configure as URIs de redirecionamento autorizadas
# 6. Copie o Client ID e Client Secret
#
# GITHUB:
# 1. Acesse https://github.com/settings/developers
# 2. Clique em "New OAuth App"
# 3. Preencha as informações do aplicativo
# 4. Configure a Authorization callback URL
# 5. Copie o Client ID e Client Secret 